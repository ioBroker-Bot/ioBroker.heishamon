{
  "name": "iobroker.heishamon",
  "version": "0.0.12",
  "description": "ioBroker adapter for Panasonic Aquarea heat pumps. Talks the CN-CNT protocol directly over a serial line (RS232 levels at the heat pump; optional RS232/RS485 converter for long cable runs) — no HeishaMon/MQTT hop required.",
  "author": "Tobias Hanss <tobias.hanss@atcetera.de>",
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "keywords": [
    "ioBroker",
    "heishamon",
    "panasonic",
    "aquarea",
    "heatpump",
    "rs232",
    "rs485",
    "cn-cnt",
    "serial"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TobiasHanss/ioBroker.heishamon.git"
  },
  "bugs": {
    "url": "https://github.com/TobiasHanss/ioBroker.heishamon/issues"
  },
  "homepage": "https://github.com/TobiasHanss/ioBroker.heishamon#readme",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:package": "mocha test/package.cjs",
    "test:integration": "mocha test/integration.cjs",
    "lint": "eslint src",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tools": "tsc -p tools/simulator/tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"tools/**/*.ts\"",
    "sim": "tsx tools/simulator/cli.ts"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@iobroker/eslint-config": "^2.3.4",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.20.0",
    "mocha": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
