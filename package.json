{
  "name": "iobroker.heishamon",
  "version": "0.0.1",
  "description": "ioBroker adapter for Panasonic Aquarea heat pumps. Talks the CN-CNT protocol directly over a serial line (RS232 levels at the heat pump; optional RS232/RS485 converter for long cable runs) — no HeishaMon/MQTT hop required.",
  "author": "Tobias Hanss <tobias.hanss@atcetera.de>",
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "keywords": [
    "ioBroker",
    "heishamon",
    "panasonic",
    "aquarea",
    "heatpump",
    "rs232",
    "rs485",
    "cn-cnt",
    "serial"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TobiasHanss/ioBroker.heishamon.git"
  },
  "bugs": {
    "url": "https://github.com/TobiasHanss/ioBroker.heishamon/issues"
  },
  "homepage": "https://github.com/TobiasHanss/ioBroker.heishamon#readme",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "admin",
    "build",
    "io-package.json",
    "LICENSE",
    "README.md",
    "INSTALL.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run test/integration",
    "lint": "eslint src test tools --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tools": "tsc -p tools/simulator/tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"tools/**/*.ts\""
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^18.19.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
