{
  "name": "iobroker.heishamon",
  "version": "0.0.1",
  "description": "ioBroker adapter for Panasonic Aquarea heat pumps. Talks the CN-CNT protocol directly over RS485 — no HeishaMon/MQTT hop required.",
  "author": "Tobias Hanss <tobias.hanss@atcetera.de>",
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "files": [
    "admin",
    "build",
    "io-package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.1.6",
    "heishamon-protocol": "*",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
